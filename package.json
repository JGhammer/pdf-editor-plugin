{
  "name": "pdf-editor-plugin",
  "version": "1.0.5",
  "description": "A PDF editor plugin for Vue and React projects with rich text editing capabilities",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "require": "./dist/react.cjs.js",
      "types": "./dist/react-entry.d.ts"
    },
    "./vue3": {
      "import": "./dist/vue3.js",
      "types": "./dist/vue3-entry.d.ts"
    },
    "./vue2": {
      "import": "./dist/vue2.js",
      "types": "./dist/vue2-entry.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "pdf",
    "editor",
    "vue",
    "react",
    "rich-text",
    "watermark"
  ],
  "author": "JGhammer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JGhammer/pdf-editor-plugin.git"
  },
  "homepage": "https://github.com/JGhammer/pdf-editor-plugin#readme",
  "bugs": {
    "url": "https://github.com/JGhammer/pdf-editor-plugin/issues"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^3.11.174",
    "quill": "^1.3.7"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@types/quill": "^2.0.14",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "rollup": "^4.0.0",
    "rollup-plugin-postcss": "^4.0.2",
    "typescript": "^5.0.0",
    "vue": "^3.4.0"
  },
  "sideEffects": [
    "**/*.css"
  ]
}
